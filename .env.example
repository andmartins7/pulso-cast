# =============================================================================
# PulsoCast — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores antes de executar.
# Em produção, configure estas variáveis diretamente nas Lambda functions.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS — compartilhado por todos os módulos
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR

# -----------------------------------------------------------------------------
# image_gen/lambda_handler.py
# -----------------------------------------------------------------------------
IMAGE_BUCKET=pulsocast-assets           # S3 bucket para imagens geradas
S3_PREFIX=generated-images             # prefixo de chave dentro do bucket
S3_URL_TYPE=presigned                  # "presigned" (dev) | "public" (prod + CloudFront)
PRESIGNED_TTL_SECONDS=3600             # TTL da URL pré-assinada em segundos (1h)
OPENAI_SECRET_NAME=/pulsocast/openai-api-key  # Secrets Manager — JSON: {"api_key": "sk-..."}

# -----------------------------------------------------------------------------
# publish/lambda_handler.py
# -----------------------------------------------------------------------------
IG_TOKEN_SECRET=/pulsocast/ig-access-token   # Secrets Manager — JSON: {"access_token": "EAA..."}
PUBLISH_TABLE=pulsocast-publish-log          # DynamoDB — audit log + métricas de engajamento

# -----------------------------------------------------------------------------
# guardrails_musicoterapia.py
# -----------------------------------------------------------------------------
ETHICS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account>/pulsocast-ethics-review
